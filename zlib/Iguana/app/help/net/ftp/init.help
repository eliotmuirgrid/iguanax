        },
        {
            "Description": "<p><em><u>string</u> </em>The name of the certificate revocation list to use during peer validation.</p>",
            "Name": "crl_file",
            "Required": false
        },
        {
            "Description": "<p><em><u>string</u> U</em>se a particular SSL version(s).</p>",
            "Name": "ssl_version",
