        },
        {
            "Description": "<p><em><u>string</u> </em>The certificate(s) file to use for peer verification.</p>",
            "Name": "ca_file",
            "Required": false
        },
        {
            "Description": "<p><em><u>string</u> </em>The PEM certificate file to validate the issuer of the peer's certificate during peer validation.</p>",
            "Name": "issuer_cert",
