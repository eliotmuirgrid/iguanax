   <outgoing_config>0</outgoing_config>
   <vmd_description></vmd_description>
   <use_dotnet_properties>True</use_dotnet_properties>
   <global name="global">
      <message name="ORUR01">
         <description>Unsolicited Observation Message</description>
         <table_grammar name="ORUR01">
            <type>group</type>
         </table_grammar>
      </message>
      <message name="ORUR30">
         <description>Of-care Observation Message Without Existing Order</description>
         <table_grammar name="ORUR30">
            <type>group</type>
         </table_grammar>
      </message>
      <message name="ORUR31">
         <description>Of-care Observation Message - Search For An Order</description>
         <table_grammar name="ORUR31">
            <type>group</type>
         </table_grammar>
      </message>
