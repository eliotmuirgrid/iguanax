         <mask>YYYY</mask>
         <mask>MM</mask>
         <mask>DD</mask>
      </date_time>
      <date_time name="Time">
         <description>Time and zone</description>
         <fields_required>False</fields_required>
         <mask>HH</mask>
         <mask>mm</mask>
         <mask>SS</mask>
         <mask>.SSSS</mask>
         <mask>+/-ZZZZ</mask>
      </date_time>
      <date_time name="Time Stamp">
